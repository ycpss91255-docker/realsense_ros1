<?xml version="1.0"?>
<!--
  Repo-owned wrapper launch. It INCLUDES the stock realsense2_camera
  rs_aligned_depth.launch unchanged and adds one thing ROS 1 realsense-ros
  (2.3.2) lacks: an optional YAML profile loader.

  ROS 1 realsense-ros ships no `config_file` arg; rs_aligned_depth.launch sets
  every stream param on the node via <param value="$(arg ...)"/>. So the profile
  is applied with <rosparam> AFTER the include, into the node's PRIVATE namespace
  ($(arg camera)/realsense2_camera): roslaunch sets all params before any node
  starts, and the later write wins, so the YAML overrides the launch defaults
  (verified by dumping the resolved params).

  Empty/unset config_file (the default) => the include streams the stock upstream
  defaults unchanged. initial_reset is a nodelet param (not an
  rs_aligned_depth.launch include arg), so it is set the same way.

    roslaunch /rs_camera_config.launch                                # stock defaults
    roslaunch /rs_camera_config.launch config_file:=/camera_config.yaml  # apply a profile
-->
<launch>
  <arg name="camera"        default="camera"/>
  <arg name="config_file"   default=""/>
  <arg name="initial_reset" default="true"/>

  <include file="$(find realsense2_camera)/launch/rs_aligned_depth.launch">
    <arg name="camera" value="$(arg camera)"/>
  </include>

  <param name="$(arg camera)/realsense2_camera/initial_reset" value="$(arg initial_reset)"/>

  <group if="$(eval config_file != str())">
    <rosparam command="load" file="$(arg config_file)" ns="$(arg camera)/realsense2_camera"/>
  </group>
</launch>
